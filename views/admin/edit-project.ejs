<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Project | Portfolio Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #07090f;
        --surface: #0e121c;
        --border: #1d2435;
        --text-muted: #a0a3b1;
        --accent: #ff7a00;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        background: var(--bg);
        color: #fff;
        font-family: 'Poppins', sans-serif;
      }

      .admin-header {
        background: var(--surface);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding: 1.5rem 2rem;
      }

      .admin-header h1 {
        margin: 0;
        font-size: 1.5rem;
      }

      .container {
        max-width: 600px;
        margin: 2rem auto;
        padding: 2rem;
      }

      .form-card {
        border-radius: 1.5rem;
        background: var(--surface);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 2rem;
      }

      .form-group {
        margin-bottom: 1.5rem;
      }

      label {
        display: block;
        margin-bottom: 0.65rem;
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
      }

      input,
      textarea {
        width: 100%;
        padding: 1rem 1.2rem;
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        color: #fff;
        font-family: 'Poppins', sans-serif;
        font-size: 0.95rem;
        transition: border-color 0.25s ease;
        resize: vertical;
      }

      input:focus,
      textarea:focus {
        outline: none;
        border-color: rgba(255, 122, 0, 0.5);
      }

      input::placeholder,
      textarea::placeholder {
        color: rgba(255, 255, 255, 0.4);
      }

      .error-message {
        padding: 1rem;
        border-radius: 1rem;
        background: rgba(255, 76, 76, 0.12);
        border: 1px solid rgba(255, 76, 76, 0.25);
        color: #ff9999;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
      }

      .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
      }

      .btn {
        flex: 1;
        padding: 1rem 1.5rem;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.95rem;
        transition: transform 0.2s ease, background 0.25s ease;
      }

      .btn:hover {
        transform: translateY(-2px);
      }

      .btn-primary {
        background: var(--accent);
        color: #fff;
      }

      .btn-primary:hover {
        background: #ff8c1a;
      }

      .btn-secondary {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #fff;
      }

      .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.05);
      }

      .help-text {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-top: 0.5rem;
      }
    </style>
  </head>
  <body>
    <div class="admin-header">
      <h1>Edit Project</h1>
    </div>

    <div class="container">
      <div class="form-card">
        <% if (typeof error !== 'undefined') { %>
          <div class="error-message"><%= error %></div>
        <% } %>

        <form method="post">
          <div class="form-group">
            <label for="title">Project Title *</label>
            <input type="text" id="title" name="title" placeholder="Enter project title" value="<%= project.title %>" required />
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" placeholder="Enter project description" rows="4"><%= project.description || '' %></textarea>
          </div>

          <div class="form-group">
            <label for="tags">Tags (comma-separated)</label>
            <input type="text" id="tags" name="tags" placeholder="e.g. React, Node.js, MongoDB" value="<%= project.tags.join(', ') %>" />
            <div class="help-text">Separate multiple tags with commas</div>
          </div>

          <div class="form-group">
            <label for="liveUrl">Live URL</label>
            <input type="url" id="liveUrl" name="liveUrl" placeholder="https://example.com" value="<%= project.liveUrl %>" />
          </div>

          <div class="form-group">
            <label for="githubUrl">GitHub URL</label>
            <input type="url" id="githubUrl" name="githubUrl" placeholder="https://github.com/username/project" value="<%= project.githubUrl %>" />
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <% 
              const formatDate = (date) => {
                if (!date) return '';
                return new Date(date).toISOString().split('T')[0];
              }
            %>
            <div class="form-group">
              <label for="startDate">Start Date</label>
              <input type="date" id="startDate" name="startDate" value="<%= formatDate(project.startDate) %>" />
            </div>
            <div class="form-group">
              <label for="endDate">End Date</label>
              <input type="date" id="endDate" name="endDate" value="<%= formatDate(project.endDate) %>" />
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update Project</button>
            <a href="/admin/dashboard" class="btn btn-secondary" style="text-decoration: none; display: flex; align-items: center; justify-content: center;">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>
