<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Main Profile | Portfolio Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg: #07090f;
        --surface: #0e121c;
        --border: #1d2435;
        --text-muted: #a0a3b1;
        --accent: #ff7a00;
      }
      * { box-sizing: border-box; }
      body { margin: 0; padding: 0; min-height: 100vh; background: var(--bg); color: #fff; font-family: 'Poppins', sans-serif; }
      .admin-header { background: var(--surface); border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding: 1.5rem 2rem; }
      .admin-header h1 { margin: 0; font-size: 1.5rem; }
      .container { max-width: 800px; margin: 2rem auto; padding: 2rem; }
      .form-card { border-radius: 1.5rem; background: var(--surface); border: 1px solid rgba(255, 255, 255, 0.05); padding: 2rem; }
      .form-group { margin-bottom: 1.5rem; }
      label { display: block; margin-bottom: 0.65rem; color: #fff; font-weight: 600; font-size: 0.9rem; }
      input, textarea { width: 100%; padding: 1rem 1.2rem; border-radius: 1rem; background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.08); color: #fff; font-family: 'Poppins', sans-serif; font-size: 0.95rem; transition: border-color 0.25s ease; resize: vertical; }
      input:focus, textarea:focus { outline: none; border-color: rgba(255, 122, 0, 0.5); }
      .form-actions { display: flex; gap: 1rem; margin-top: 2rem; }
      .btn { flex: 1; padding: 1rem 1.5rem; border-radius: 999px; border: none; cursor: pointer; font-weight: 600; font-size: 0.95rem; transition: transform 0.2s ease, background 0.25s ease; text-decoration: none; display: flex; align-items: center; justify-content: center; }
      .btn:hover { transform: translateY(-2px); }
      .btn-primary { background: var(--accent); color: #fff; }
      .btn-secondary { background: transparent; border: 1px solid rgba(255, 255, 255, 0.2); color: #fff; }
      .help-text { font-size: 0.85rem; color: var(--text-muted); margin-top: 0.5rem; }
    </style>
  </head>
  <body>
    <div class="admin-header">
      <h1>Manage Main Profile & Stats</h1>
    </div>

    <div class="container">
      <div class="form-card">
        <form method="post">
          <div class="form-group">
            <label for="secondaryTitle">Secondary Title (About Header)</label>
            <input type="text" id="secondaryTitle" name="secondaryTitle" value="<%= info ? info.secondaryTitle : '' %>" placeholder="e.g. Driven by technical excellence..." />
          </div>

          <div class="form-group">
            <label for="bio">Full Bio (About Section)</label>
            <textarea id="bio" name="bio" rows="6" placeholder="Detailed biography and professional overview"><%= info ? info.bio : '' %></textarea>
          </div>

          <div class="form-group">
            <label for="secondaryImage">Secondary Image URL (About Section)</label>
            <input type="url" id="secondaryImage" name="secondaryImage" value="<%= info ? info.secondaryImage : '' %>" placeholder="https://example.com/profile.jpg" />
          </div>

          <h3 style="margin: 2rem 0 1rem; font-size: 1.1rem; color: var(--accent);">Achievement Metrics</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
              <label for="internshipCount">Internships</label>
              <input type="number" id="internshipCount" name="internshipCount" value="<%= info ? info.internshipCount : 0 %>" />
            </div>
            <div class="form-group">
              <label for="aiProject">AI Projects</label>
              <input type="number" id="aiProject" name="aiProject" value="<%= info ? info.aiProject : 0 %>" />
            </div>
            <div class="form-group">
              <label for="deployedProject">Deployed Projects</label>
              <input type="number" id="deployedProject" name="deployedProject" value="<%= info ? info.deployedProject : 0 %>" />
            </div>
            <div class="form-group">
              <label for="groupProjects">Group Projects</label>
              <input type="number" id="groupProjects" name="groupProjects" value="<%= info ? info.groupProjects : 0 %>" />
            </div>
          </div>

          <div class="form-group">
            <label for="skills">Skills (Comma separated list)</label>
            <textarea id="skills" name="skills" rows="3" placeholder="e.g. React, Node.js, Python, AWS, Docker"><%= info ? info.skills.join(', ') : '' %></textarea>
            <div class="help-text">These will be displayed as pill-tags on the home page.</div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Profile</button>
            <a href="/admin/dashboard" class="btn btn-secondary">Back to Dashboard</a>
          </div>
        </form>
      </div>
    </div>
  </body>
</html>
