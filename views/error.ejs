<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="icon" type="image/png" href="/favicon.png">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PortFolio</title>
    <meta name="description" content="Personal portfolio website" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="error-page">
    <div class="error-container reveal">
        <h1 class="error-code">500</h1>
        <h2 class="error-title">System Error</h2>
        <p class="error-message">Something went wrong on our end. We're looking into it!</p>
        
        <% if (locals.message) { %>
            <div class="error-details">
                <p style="margin-bottom: 0.5rem; font-weight: bold; color: #ff7a00;">Technical Details:</p>
                <pre><%= message %></pre>
            </div>
        <% } %>

        <div class="error-actions" style="margin-top: 2rem;">
            <a href="/MyPort/home" class="button">Back to Home</a>
            <button onclick="window.location.reload()" class="button button-alt">Retry</button>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const container = document.querySelector('.error-container');
            container.style.opacity = '0';
            container.style.transform = 'translateY(20px)';
            container.style.transition = 'all 0.8s cubic-bezier(0.23, 1, 0.32, 1)';
            
            setTimeout(() => {
                container.style.opacity = '1';
                container.style.transform = 'translateY(0)';
            }, 100);
        });
    </script>
</body>
</html>
