<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" type="image/png" href="/favicon.png">
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PortFolio</title>
    <meta name="description" content="Personal portfolio website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="page-shell">
      <%- include('partials/navbar') %>

      <main>
        <section class="details-hero">
          <div class="container reveal">
            <a href="/MyPort/home#portfolio" class="button button-small button-alt" style="margin-bottom: 2rem;">← Back to Projects</a>
            <div class="details-header">
              <p class="section-label">Project Case Study</p>
              <h1><%= project.title %></h1>
            </div>
          </div>
        </section>

        <section class="details-content">
          <div class="container details-grid">
            <div class="details-main reveal">
              <p><%= project.description %></p>
            </div>
            
            <aside class="details-sidebar reveal">
              <div class="sidebar-item">
                <h4>Technologies</h4>
                <div class="sidebar-tags">
                  <% project.tags.forEach(function(tag) { %>
                    <span><%= tag %></span>
                  <% }); %>
                </div>
              </div>
              
              <div class="sidebar-item">
                <h4>Links</h4>
                <div class="project-actions">
                  <% if (project.liveUrl && project.liveUrl !== '#') { %>
                    <a href="<%= project.liveUrl %>" class="button" target="_blank">Live Preview</a>
                  <% } %>
                  <% if (project.githubUrl && project.githubUrl !== '#') { %>
                    <a href="<%= project.githubUrl %>" class="button button-alt" target="_blank">Source Code</a>
                  <% } %>
                </div>
              </div>
              
              <div class="sidebar-item">
                <h4>Project Duration</h4>
                <p style="color: #fff;">
                  <% 
                    const options = { year: 'numeric', month: 'long' };
                    const startDisp = project.startDate ? new Date(project.startDate).toLocaleDateString(undefined, options) : '';
                    const endDisp = project.endDate ? new Date(project.endDate).toLocaleDateString(undefined, options) : 'Present';
                  %>
                  <%= startDisp %> <%= project.startDate && project.endDate ? '—' : '' %> <%= project.endDate ? endDisp : (project.startDate ? 'Present' : 'Not specified') %>
                </p>
              </div>
            </aside>
          </div>
        </section>

        <% if (images && images.length > 0) { %>
        <section class="gallery-section">
          <div class="container">
            <div class="section-header reveal">
              <p class="section-label">Gallery</p>
              <h2>Visual Showcase</h2>
            </div>
            
            <div class="gallery-grid">
              <% images.forEach(function(image) { %>
                <div class="gallery-item reveal">
                  <img src="<%= image.url %>" alt="<%= image.caption %>" loading="lazy" />
                  <% if (image.caption) { %>
                    <div class="gallery-caption"><%= image.caption %></div>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>
        </section>
        <% } %>
      </main>

      <%- include('partials/footer') %>
    </div>

    <script src="/js/main.js"></script>
    <script>
      window.addEventListener('DOMContentLoaded', () => {
        const revealObserver = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
      });
    </script>
  </body>
</html>
